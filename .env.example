APP_NAME=moly-backend
ENVIRONMENT=local

# --- Supabase (Auth + Postgres + pgvector) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# JWT 검증(JWKS 로컬 검증) — 미설정 시 remote getUser 폴백(auth 설계 단계에서 확정)
SUPABASE_JWKS_URL=
# API 서버 전용 DB 쓰기(서비스 롤). 클라 직접 쓰기 없음(ERD §8)
SUPABASE_DB_CONNECTION_STRING=

# --- Anthropic Claude (대화·개인일기=Sonnet / self-check·기억통합=Haiku) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_CHAT=claude-sonnet-5
ANTHROPIC_MODEL_UTILITY=claude-haiku-4-5-20251001

# --- FCM 푸시(Firebase Cloud Messaging) — 워커 아침/저녁 알림 ---
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_FILE=          # service account JSON 경로(예: secrets/fcm-service-account.json)

# --- App Store(StoreKit) — 구독/IAP 검증·조회, ASSN 웹훅 ---
APP_STORE_PRIVATE_KEY_FILE=        # .p8 경로(예: secrets/AuthKey_XXXXXXXXXX.p8)
APP_STORE_KEY_ID=                  # 키 ID 10자리(파일명 AuthKey_<이것>.p8)
APP_STORE_ISSUER_ID=              # 발급자 ID UUID(App Store Connect 통합 탭 상단, 계정당 1개)
APP_STORE_BUNDLE_ID=              # 앱 번들 ID(예: com.geniusjun.moly)
APP_STORE_ENVIRONMENT=Sandbox     # Sandbox | Production

# --- mem0 (장기기억, 같은 Supabase pgvector) — 추출/임베딩은 OpenAI ---
OPENAI_API_KEY=
EMBEDDER_MODEL=text-embedding-3-small
MEMORY_LLM_MODEL=gpt-4.1-mini
