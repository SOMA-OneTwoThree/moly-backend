APP_NAME=moly-backend
ENVIRONMENT=local

# --- Supabase (Auth + Postgres + pgvector) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# JWT 검증(JWKS 로컬 검증) — 미설정 시 remote getUser 폴백(auth 설계 단계에서 확정)
SUPABASE_JWKS_URL=
# API 서버 전용 DB 쓰기(서비스 롤). 클라 직접 쓰기 없음(ERD §8)
SUPABASE_DB_CONNECTION_STRING=

# --- Anthropic Claude (대화·개인일기=Sonnet / self-check=Haiku) ---
# 대화 Haiku A/B는 ANTHROPIC_MODEL_CHAT만 claude-haiku-4-5로 바꾸면 된다(일기는 안 딸려간다).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_CHAT=claude-sonnet-5
ANTHROPIC_MODEL_DIARY=claude-sonnet-5
ANTHROPIC_MODEL_UTILITY=claude-haiku-4-5-20251001

# --- FCM 푸시(Firebase Cloud Messaging) — 워커 아침/저녁 알림 ---
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_FILE=          # service account JSON 경로(예: secrets/fcm-service-account.json)

# --- App Store(StoreKit) — JWS x5c 서명검증(구독/IAP/ASSN 웹훅) ---
# 서명검증만 하므로 .p8/Key ID/Issuer ID 불필요(App Store Server API 조회 안 함). Bundle ID면 충분.
APP_STORE_BUNDLE_ID=              # 앱 번들 ID(예: com.geniusjun.moly) — 미설정 시 로컬 미검증/비로컬 거부
APP_STORE_ENVIRONMENT=Sandbox     # Sandbox | Production
APP_STORE_APP_APPLE_ID=          # 앱 숫자 ID(App Store Connect 앱 정보) — Production 알림 검증 시 필요

# --- mem0 (장기기억, 같은 Supabase pgvector) — 추출/임베딩은 OpenAI ---
OPENAI_API_KEY=
EMBEDDER_MODEL=text-embedding-3-small
MEMORY_LLM_MODEL=gpt-4.1-mini
MEMORY_PROVIDER_TIMEOUT_SECONDS=15
MEMORY_PROVIDER_MAX_RETRIES=0
MEMORY_INGESTION_ENABLED=false
MEMORY_INGESTION_BATCH_SIZE=50
MEMORY_INGESTION_MAX_ATTEMPTS=8
MEMORY_INGESTION_TIMEOUT_SECONDS=90
MEMORY_RECALL_MODE=legacy
MEMORY_RECALL_ROLLOUT_PERCENT=0
MEMORY_RECALL_SEARCH_TOP_K=12
MEMORY_RECALL_SEARCH_THRESHOLD=0.25
MEMORY_RECALL_TIMEOUT_MS=800
MEMORY_RECALL_QUERY_MAX_CHARS=1200
MEMORY_RECALL_MAX_ITEMS=4
MEMORY_RECALL_MAX_CHARS=800
